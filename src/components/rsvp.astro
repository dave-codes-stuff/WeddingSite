---
// src/components/RSVPForm.astro
---

<div class="rsvp-container">
  
  <form id="rsvp-form" action="POST" name="RSVP Form" data-netlify="true">
    <h2>Will you be attending?</h2>
    <label for="party">Choose party:
      <select name="party" id="party-members" size="1" required>
        <option value="" disabled selected>--Select your party--</option>
        <option value="Jeff Cockerill">Mr. & Mrs. Jeffrey Cockerill, Zoey</option>
        <option value="Samuel Covington">Mr. & Mrs. Samuel Covington, Ivor, Juno</option>
        <option value="Adams, Mr. Robin / +1">Adams, Mr. Robin / +1</option>
      </select>
    </label>
    
    <label id="plus1-section">
      Will you be bringing a guest?
      <select name="plus1-selector">
        <option value="" disabled selected>--Select an option--</option>
        <option value="yes">Yes</option>
        <option value="no">No</option>
      </select>
    </label>

    <label>
      Will you attend?
      <select name="attendance" required>
        <option value="" disabled selected>--Select an option--</option>
        <option value="yes">Yes</option>
        <option value="no">No</option>
      </select>
    </label>

    <label>
      Dietary Restrictions / Notes:
      <textarea name="dietary_additional" placeholder="e.g. Vegan, Gluten-free, Some party members won't be attending..." rows="5"></textarea>
    </label>

    <button type="submit">Send RSVP</button>
  </form>
  
  <p id="response-msg">Thanks!</p>
</div>

<script>
  const form = document.getElementById('rsvp-form') as HTMLFormElement;
  const msg = document.getElementById('response-msg');
  const guestSelection = document.getElementById('party-members')
  const plus1section = document.getElementById("plus1-section")
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    fetch("/", { 
        method: 'POST',
        body: formData
    });

    form.style.display = 'none';
    if (msg) msg.style.display = 'block';



  })

  guestSelection?.addEventListener('input', function(e) {

      if (guestSelection.value.includes("+1")) {
        plus1section.style.display = 'contents'

      } else {
        plus1section.style.display = 'none'
      }

  })

</script>

<style>

.rsvp-container {
    max-width: 360px;
    height: auto;
    margin: .75rem auto 2rem auto;
    padding: 1.2rem;
    border: 3px solid var(--light-blue-color);
    border-radius: 8px;
    background-color: var(--dark-blue-color);
    color: var(--off-white-color);
    font-family: var(--font-primary);
}

#response-msg {
    /* margin-top: 180px; */
    margin: 180px 0px 180px 0px;
    text-align: center;
    display: none;
    font-family: var(--font-primary);
    font-size: 1.4rem;
    font-weight: 700;

}

#plus1-section {
  display: none;
}
  
form { 
    display: flex; 
    flex-direction: column; 
    gap: 1rem;
    height: auto;
}

label {
    display: flex;
    flex-direction: column;
    font-weight: bold;
}

input, select, textarea { 
    padding: 0.5rem; 
    margin-top: 0.75rem; 
}

select {
    cursor: pointer;
    overflow-wrap: break-word;
}

option {
  overflow-wrap: break-word;
}

h2 {
    text-align: center;
    margin-bottom: 0%;
}

button {
    padding: 12px;
    margin: 5px 10px auto 10px;
    background-color: var(--blue-green-color);
    cursor: pointer;
    border-radius: 8px;
    font-weight: bold;
}

</style>