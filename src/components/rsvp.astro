    font-family: var(--font-primary);
}

#response-msg {
    /* margin-top: 180px; */
    margin: 180px 0px 180px 0px;
    text-align: center;
    display: none;
    font-family: var(--font-primary);
    font-size: 1.4rem;
    font-weight: 700;

}

#plus1-section {
  display: none;
}
  
form { 
    display: flex; 
    flex-direction: column; 
    gap: 1rem;
    height: auto;
}

label {
    display: flex;
    flex-direction: column;
    font-weight: bold;
}

input, select, textarea { 
    padding: 0.5rem; 
    margin-top: 0.75rem; 
}

select {
    cursor: pointer;
    overflow-wrap: break-word;
}

option {
  overflow-wrap: break-word;
}

h2 {
    text-align: center;
    margin-bottom: 0%;
}

button {
    padding: 12px;
    margin: 5px 10px auto 10px;
    background-color: var(--blue-green-color);
    cursor: pointer;
    border-radius: 8px;
    font-weight: bold;
}

</style>